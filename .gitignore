# ----------------------------------------------------------------------
# Datasets (large, never in repo)
# ----------------------------------------------------------------------
data/
corpus/raw/*
!corpus/raw/.gitkeep
corpus/cleaned/*
!corpus/cleaned/.gitkeep
corpus/chunks/*
!corpus/chunks/.gitkeep
corpus/vector_db/*
!corpus/vector_db/.gitkeep

# ----------------------------------------------------------------------
# Trained model artifacts
# ----------------------------------------------------------------------
models/*
!models/.gitkeep
*.ckpt
*.pt
*.pth
*.safetensors
*.bin

# ----------------------------------------------------------------------
# Results & logs
# ----------------------------------------------------------------------
results/logs/*
!results/logs/.gitkeep
results/figures/*
!results/figures/.gitkeep
results/*.pkl
results/*.json
results/disease/tensorboard/
results/soil/tensorboard/

# ----------------------------------------------------------------------
# Python build / cache
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ----------------------------------------------------------------------
# Tooling caches
# ----------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ----------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----------------------------------------------------------------------
# IDE
# ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------------------------------------------------
# Environments
# ----------------------------------------------------------------------
.env
.venv/
venv/
ENV/
env/

# ----------------------------------------------------------------------
# OS
# ----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log

# ----------------------------------------------------------------------
# Scratch
# ----------------------------------------------------------------------
experiments/
tmp/
temp/
.cache/
cache/

# ----------------------------------------------------------------------
# Credentials
# ----------------------------------------------------------------------
*.key
*.pem
credentials.json
secrets.yaml
