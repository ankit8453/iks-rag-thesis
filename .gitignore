# ----------------------------------------------------------------------
# Image datasets (large, never in repo)
# Per master reference §41: data/ is for image datasets only;
# corpus/ is exclusively the IKS classical-text corpus.
# data/splits/ is intentionally NOT ignored — split JSONs are tracked.
# ----------------------------------------------------------------------
data/plant_disease/*
!data/plant_disease/.gitkeep
data/soil/*
!data/soil/.gitkeep

# IKS corpus directories
corpus/raw/*
!corpus/raw/.gitkeep
corpus/cleaned/*
!corpus/cleaned/.gitkeep
corpus/chunks/*
!corpus/chunks/.gitkeep
corpus/vector_db/*
!corpus/vector_db/.gitkeep

# ----------------------------------------------------------------------
# Trained model artifacts
# ----------------------------------------------------------------------
models/*
!models/.gitkeep
*.ckpt
*.pt
*.pth
*.safetensors
*.bin

# ----------------------------------------------------------------------
# Results & logs
# ----------------------------------------------------------------------
results/logs/*
!results/logs/.gitkeep
results/figures/*
!results/figures/.gitkeep
results/*.pkl
results/*.json
results/disease/tensorboard/
results/soil/tensorboard/

# ----------------------------------------------------------------------
# Python build / cache
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ----------------------------------------------------------------------
# Tooling caches
# ----------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ----------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----------------------------------------------------------------------
# IDE
# ----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------------------------------------------------
# Environments
# ----------------------------------------------------------------------
.env
.venv/
venv/
ENV/
env/

# ----------------------------------------------------------------------
# OS
# ----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log

# ----------------------------------------------------------------------
# Scratch
# ----------------------------------------------------------------------
experiments/
tmp/
temp/
.cache/
cache/

# ----------------------------------------------------------------------
# Credentials
# ----------------------------------------------------------------------
*.key
*.pem
credentials.json
secrets.yaml
