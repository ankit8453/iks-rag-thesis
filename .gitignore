# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
.DS_Store

# Data (large, gitignored per §41 contents but tracking placeholders)
data/plant_disease/*
data/soil/*
data/causation/*
!data/plant_disease/.gitkeep
!data/soil/.gitkeep
!data/causation/.gitkeep
# data/splits/ is intentionally tracked — small JSON split files
# data/soil/vit_texture/INTEGRATION_AUDIT.json is intentionally tracked —
# tiny provenance manifest written by scripts/integrate_latha_soil.py.
# Images themselves stay ignored (regenerable from the upstream repo).
!data/soil/vit_texture/
data/soil/vit_texture/*
!data/soil/vit_texture/INTEGRATION_AUDIT.json

# Corpus working artifacts (raw OCR and embeddings are large)
corpus/raw/*
!corpus/raw/.gitkeep
corpus/vector_db/*
!corpus/vector_db/.gitkeep
# cleaned/ and chunks/ are intentionally tracked once produced

# Models
# Phase 5+ trained checkpoints under models/disease/ ARE tracked via
# Git LFS (.pt files) and plain Git (small JSON metric files). Anything
# else under models/ (ad-hoc TensorBoard runs, inference caches,
# partial downloads) stays ignored.
models/*.tmp
models/disease/**/*.pt.tmp
models/runs/
# Keep the original placeholder so an empty models/ dir is preserved
# when nothing has been pulled yet.
!models/.gitkeep

# Results
results/logs/*
!results/logs/.gitkeep
results/figures/*.png
results/figures/*.pdf
!results/figures/.gitkeep

# Local environment
.env

kaggle.json
.kaggle/

# Phase 5 smoke-test scratch / inference cache / checkpoint scratch
_smoke_work/
_inference/
_checkpoints/

# One-off zip archives dropped at repo root for manual integrations
# (e.g. latha-soil-main.zip used by scripts/integrate_latha_soil.py)
/*.zip
