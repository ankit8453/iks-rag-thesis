# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
.DS_Store

# Data (large, gitignored per §41 contents but tracking placeholders)
data/plant_disease/*
data/soil/*
!data/plant_disease/.gitkeep
!data/soil/.gitkeep
# splits/ is intentionally tracked — those are small JSON files

# Corpus working artifacts (raw OCR and embeddings are large)
corpus/raw/*
!corpus/raw/.gitkeep
corpus/vector_db/*
!corpus/vector_db/.gitkeep
# cleaned/ and chunks/ are intentionally tracked once produced

# Models (per §41 — gitignored)
models/*
!models/.gitkeep

# Results
results/logs/*
!results/logs/.gitkeep
results/figures/*.png
results/figures/*.pdf
!results/figures/.gitkeep

# Local environment
.env

kaggle.json
.kaggle/